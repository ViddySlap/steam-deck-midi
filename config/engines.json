{
  "engines": [
    {
      "name": "Audio Engine",
      "type": "audio_opacity",
      "enabled": true,
      "sample_size": 8,
      "update_hz": 30,
      "inputs": {
        "channel": 14,
        "cc_audio": 100,
        "cc_enable": 101,
        "cc_video_stomp": 102,
        "cc_logo_stomp": 103,
        "cc_tipping": 104,
        "cc_duration": 105,
        "cc_attack": 106,
        "cc_release": 107,
        "cc_video_delay": 108,
        "cc_logo_delay": 109,
        "duration_max_seconds": 5.0,
        "attack_max_seconds": 5.0,
        "release_max_seconds": 5.0,
        "video_delay_max_seconds": 5.0,
        "logo_delay_max_seconds": 5.0
      },
      "outputs": {
        "protocol": "osc",
        "osc": {
          "host": "127.0.0.1",
          "port": 7000,
          "video_path": "/composition/groups/1/master",
          "logo_path": "/composition/groups/2/master"
        },
        "channel": 0,
        "cc_video_master": 110,
        "cc_logo_master": 111
