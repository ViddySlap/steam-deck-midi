{
  "engines": [
    {
      "name": "Audio Engine",
      "type": "audio_opacity",
      "enabled": true,
      "sample_size": 8,
      "update_hz": 30,
      "inputs": {
        "channel": 14,
        "cc_audio": 100,
        "cc_enable": 101,
        "cc_video_stomp": 102,
        "cc_logo_stomp": 103,
        "cc_tipping": 104,
        "cc_duration": 105,
        "cc_attack": 106,
        "cc_release": 107,
        "cc_video_delay": 108,
        "cc_logo_delay": 109,
        "duration_max_seconds": 5.0,
        "attack_max_seconds": 5.0,
        "release_max_seconds": 5.0,
        "video_delay_max_seconds": 5.0,
        "logo_delay_max_seconds": 5.0
      },
      "outputs": {
        "protocol": "osc",
        "osc": {
          "host": "127.0.0.1",
          "port": 7000,
          "video_path": "/composition/groups/1/master",
          "logo_path": "/composition/groups/2/master"
        },
        "channel": 0,
        "cc_video_master": 110,
        "cc_logo_master": 111
      },
      "defaults": {
        "tipping_point": 0.65,
        "duration_seconds": 1.0,
        "attack_seconds": 0.0,
        "release_seconds": 1.0,
        "video_delay_seconds": 0.0,
        "logo_delay_seconds": 1.0
      }
    },
    {
      "name": "Layer 9/10 Auto-Bypass",
      "type": "auto_bypass",
      "enabled": true,
      "rest": {
        "base_url": "http://127.0.0.1:8080",
        "timeout_seconds": 1.5
      },
      "poll_hz": 5,
      "threshold": 0.01,
      "debounce_ms": 500,
      "read_param": "master",
      "targets": [
        {"kind": "layer", "index": 9, "label": "Layer 9 FEEDBACK"},
        {"kind": "layer", "index": 10, "label": "Layer 10 COMP LEVEL FX"}
      ]
    }
  ]
}
