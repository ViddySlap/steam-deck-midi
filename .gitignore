# User-managed preset files (default.json is the factory default and is tracked)
config/presets/*
!config/presets/default.json

# Playwright test artifacts
tests/playwright_screenshot.png

# Session debug logs
.session-logs/
bridge.log
bridge.log.err

# Local scratch + comp backups (not source-of-truth)
scratch/
backups/

# Local dev-bridge runtime logs
logs/
dev-bridge.out.log
dev-bridge.err.log
gyro-observe.log
